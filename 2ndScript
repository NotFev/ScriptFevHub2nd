-- Toggle & Button creators
local function CreateToggle(parent, text, settingName, yOffset)
    local toggle = Instance.new("TextButton")
    toggle.Size = UDim2.new(0, 500, 0, 58)
    toggle.Position = UDim2.new(0, 15, 0, yOffset)
    toggle.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
    toggle.Text = "⬜  " .. text
    toggle.TextColor3 = Color3.fromRGB(220, 220, 220)
    toggle.TextXAlignment = Enum.TextXAlignment.Left
    toggle.Font = Enum.Font.GothamSemibold
    toggle.TextScaled = true
    toggle.Parent = parent
    local corner = Instance.new("UICorner"); corner.CornerRadius = UDim.new(0, 14); corner.Parent = toggle
    
    toggle.MouseButton1Click:Connect(function()
        getgenv().FevHub[settingName] = not getgenv().FevHub[settingName]
        toggle.BackgroundColor3 = getgenv().FevHub[settingName] and Color3.fromRGB(0, 220, 140) or Color3.fromRGB(35, 35, 35)
        toggle.Text = getgenv().FevHub[settingName] and "✅  " .. text or "⬜  " .. text
    end)
end

local function CreateButton(parent, text, yOffset, callback)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, 500, 0, 58)
    btn.Position = UDim2.new(0, 15, 0, yOffset)
    btn.BackgroundColor3 = Color3.fromRGB(0, 150, 255)
    btn.Text = "➤  " .. text
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.Font = Enum.Font.GothamSemibold
    btn.TextScaled = true
    btn.Parent = parent
    local corner = Instance.new("UICorner"); corner.CornerRadius = UDim.new(0, 14); corner.Parent = btn
    btn.MouseButton1Click:Connect(callback)
end

