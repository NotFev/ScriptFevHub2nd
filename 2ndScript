-- Main Farm Loop (the heart of the script)
task.spawn(function()
    while task.wait(0.15) do
        pcall(function()
            local plr = game.Players.LocalPlayer
            local char = plr.Character
            if not char or not char:FindFirstChild("HumanoidRootPart") then return end

            local root = char.HumanoidRootPart
            local bestTarget = nil
            local shortestDist = math.huge

            for _, enemy in ipairs(game.Workspace.Enemies:GetChildren()) do
                if enemy:FindFirstChild("Humanoid") and enemy.Humanoid.Health > 0 and enemy:FindFirstChild("HumanoidRootPart") then
                    local dist = (root.Position - enemy.HumanoidRootPart.Position).Magnitude

                    if dist < shortestDist and dist <= getgenv().FEVSettings.FarmDistance then
                        if getgenv().FEVSettings.FarmMethod == "Boss Farm" then
                            if string.find(enemy.Name:lower(), "boss") or string.find(enemy.Name:lower(), "raid") or string.find(enemy.Name:lower(), "king") then
                                bestTarget = enemy
                                shortestDist = dist
                            end
                        else
                            bestTarget = enemy
                            shortestDist = dist
                        end
                    end
                end
            end

            if bestTarget then
                root.CFrame = bestTarget.HumanoidRootPart.CFrame * CFrame.new(0, 0, 5)

                -- Bring Mobs
                if getgenv().FEVSettings.BringMobs then
                    for _, mob in ipairs(game.Workspace.Enemies:GetChildren()) do
                        if mob:FindFirstChild("HumanoidRootPart") and (mob.HumanoidRootPart.Position - bestTarget.HumanoidRootPart.Position).Magnitude < 50 then
                            mob.HumanoidRootPart.CFrame = bestTarget.HumanoidRootPart.CFrame
                        end
                    end
                end
            end
        end)
    end
end)

-- NoClip
game:GetService("RunService").Stepped:Connect(function()
    if getgenv().FEVSettings.NoClip and game.Players.LocalPlayer.Character then
        for _, part in pairs(game.Players.LocalPlayer.Character:GetDescendants()) do
            if part:IsA("BasePart") and part.CanCollide then
                part.CanCollide = false
            end
        end
    end
end)

-- Auto Eat Fruit (when inventory has one)
task.spawn(function()
    while task.wait(10) do
        if getgenv().FEVSettings.AutoEatFruit then
            pcall(function()
                for _, tool in ipairs(game.Players.LocalPlayer.Backpack:GetChildren()) do
                    if tool:IsA("Tool") and string.find(tool.Name:lower(), "fruit") then
                        game.Players.LocalPlayer.Character.Humanoid:EquipTool(tool)
                        task.wait(0.5)
                        tool:Activate()
                    end
                end
            end)
        end
    end
end)

