                    local isBoss = getgenv().FevHub.AutoBoss and (enemy.Humanoid.MaxHealth > 8000 or enemy.Name:find("Boss") or enemy.Name:find("Raid"))
                    if (isBoss or not getgenv().FevHub.AutoBoss) and d < dist and d <= getgenv().FevHub.FarmDistance then
                        best, dist = enemy, d
                    end
                end
            end

            if best then
                root.CFrame = best.HumanoidRootPart.CFrame * CFrame.new(0, 0, 5)
